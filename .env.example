# ============================================================
# GoServi Backend - Variables de Entorno
# ============================================================
# Copia este archivo a .env y rellena los valores
# NUNCA subas .env a Git
# ============================================================

# Base de datos
DATABASE_URL=jdbc:postgresql://localhost:5432/goservi
DB_USERNAME=postgres
DB_PASSWORD=tu_password_aqui

# JWT (mínimo 32 caracteres, cámbialo en producción)
JWT_SECRET=cambia_este_secret_por_uno_muy_largo_y_seguro_en_prod
JWT_EXPIRATION=86400000

# Gmail SMTP
MAIL_USERNAME=tu_email@gmail.com
MAIL_PASSWORD=tu_app_password_de_gmail

# Twilio (SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=tu_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Cloudinary (imágenes)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Wompi (pagos Colombia)
# Sandbox: https://sandbox.wompi.co/v1
# Producción: https://production.wompi.co/v1
WOMPI_URL=https://sandbox.wompi.co/v1
WOMPI_PUBLIC_KEY=pub_test_xxxxxxxxxxxxxxxx
WOMPI_PRIVATE_KEY=prv_test_xxxxxxxxxxxxxxxx
WOMPI_EVENTS_SECRET=test_events_xxxxxxxxxxxxxxxx
WOMPI_INTEGRITY_SECRET=test_integrity_xxxxxxxxxxxxxxxx

# Google Maps API
GOOGLE_MAPS_API_KEY=AIzaSy_tu_api_key

# Puerto (Railway lo setea automáticamente)
PORT=8080
